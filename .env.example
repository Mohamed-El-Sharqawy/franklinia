# Database - Use the Internal DB URL from Coolify's PostgreSQL service settings
DATABASE_URL=postgresql://user:password@<coolify-postgres-hostname>:5432/database?schema=public

# Coolify DB network name - find it on your VPS with: docker network ls
# Usually the format is: <project-uuid> (shown in Coolify under the DB service)
COOLIFY_DB_NETWORK=coolify

# JWT Secret - Generate a strong random string
JWT_SECRET=your-super-secret-jwt-key-change-this

# CORS Origins - comma-separated list of allowed origins (use * for all in development)
CORS_ORIGIN=*

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# API URLs - Update these with your domain
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
VITE_API_URL=https://api.yourdomain.com

# Site URL (for sitemap and SEO)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Stripe
# For local dev, get these from the Stripe Dashboard (Secret Key) 
# and from the Stripe CLI output when running 'stripe listen' (Webhook Secret)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
