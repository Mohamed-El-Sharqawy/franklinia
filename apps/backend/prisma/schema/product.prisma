enum ProductBadge {
  NEW
  BESTSELLER
  LIMITED_EDITION
}

model Product {
  id   String @id @default(cuid())
  slug String @unique

  nameEn             String
  nameAr             String
  descriptionEn      String   @db.Text
  descriptionAr      String   @db.Text
  shortDescriptionEn String?  @db.Text
  shortDescriptionAr String?  @db.Text

  metaTitleEn       String?
  metaTitleAr       String?
  metaDescriptionEn String?  @db.Text
  metaDescriptionAr String?  @db.Text

  baseCategory BaseCategory
  isActive      Boolean @default(true)
  isFeatured    Boolean @default(false)
  badge         ProductBadge?
  isTrending    Boolean @default(false)
  position      Int     @default(0)

  collection   Collection? @relation(fields: [collectionId], references: [id])
  collectionId String?

  // Fashion attributes (1:1)
  fashionAttributes FashionAttributes?

  // Occasion associations (N:N)
  occasions ProductOccasion[]

  // Display variants for listing cards
  defaultVariant   ProductVariant? @relation("ProductDefaultVariant", fields: [defaultVariantId], references: [id])
  defaultVariantId String?
  hoverVariant     ProductVariant? @relation("ProductHoverVariant", fields: [hoverVariantId], references: [id])
  hoverVariantId   String?

  variants        ProductVariant[] @relation("ProductVariants")
  options         ProductOption[]
  customFields    ProductCustomField[]
  images          ProductImage[]
  favourites      Favourite[]
  wishlist        Wishlist[]
  shoppableVideos ShoppableVideo[]
  reviews         Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([collectionId])
  @@index([baseCategory])
  @@index([isActive, isFeatured])
  @@index([isTrending])
  @@index([position])
  @@index([badge])
  @@index([createdAt])
  @@map("products")
}

model ProductVariant {
  id    String @id @default(cuid())
  slug  String @unique

  product   Product @relation("ProductVariants", fields: [productId], references: [id], onDelete: Cascade)
  productId String

  // Back-references for display variant relations
  productsAsDefault Product[] @relation("ProductDefaultVariant")
  productsAsHover   Product[] @relation("ProductHoverVariant")

  nameEn         String // e.g. "Red / M", "Blue / L"
  nameAr         String
  sku            String?  @unique
  price          Float
  compareAtPrice Float?

  stock          Int     @default(0)
  fitAdjustment  FitAdjustment?
  isActive       Boolean @default(true)

  metaTitleEn       String?
  metaTitleAr       String?
  metaDescriptionEn String?  @db.Text
  metaDescriptionAr String?  @db.Text

  images     ProductVariantImage[]
  optionValues ProductOptionValue[]
  orderItems OrderItem[]
  cartItems  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([sku])
  @@index([slug])
  @@index([isActive])
  @@map("product_variants")
}

// Product-level images that can be shared across variants
model ProductImage {
  id        String  @id @default(cuid())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  url      String
  publicId String // Cloudinary public ID for deletion
  altEn    String?
  altAr    String?

  // Junction table for many-to-many with variants
  variantImages ProductVariantImage[]

  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

// Junction table: links images to variants with position per variant
model ProductVariantImage {
  id String @id @default(cuid())

  image   ProductImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
  imageId String

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId String

  position Int @default(0) // Position of this image within this specific variant

  @@unique([imageId, variantId]) // Each image can only be linked once per variant
  @@index([variantId])
  @@index([imageId])
  @@index([position])
  @@map("product_variant_images")
}

enum CustomFieldType {
  TEXT
  TEXTAREA
  NUMBER
  FILE
}

model ProductCustomField {
  id     String          @id @default(cuid())
  type   CustomFieldType @default(TEXT)
  labelEn String
  labelAr String
  placeholderEn String?
  placeholderAr String?
  isRequired    Boolean @default(false)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("product_custom_fields")
}
