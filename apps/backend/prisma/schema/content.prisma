// Shoppable Videos - videos linked to products
model ShoppableVideo {
  id String @id @default(cuid())

  // Video details
  videoUrl          String // Cloudinary video URL
  videoPublicId     String // Cloudinary public ID for deletion
  thumbnailUrl      String // Thumbnail image URL
  thumbnailPublicId String // Thumbnail public ID

  // Linked product
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  position Int     @default(0) // Display order
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([position])
  @@index([isActive])
  @@map("shoppable_videos")
}

// Customer Reviews linked to products
model Review {
  id String @id @default(cuid())

  // Linked product (required)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  // Reviewer info (can be linked to user or guest)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId String?

  // Guest reviewer info (if not logged in)
  customerName String

  // Review content
  title   String
  content String @db.Text
  rating  Int    @default(5) // 1-5 stars

  isApproved Boolean @default(false) // Admin approval
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([userId])
  @@index([isApproved])
  @@index([isActive])
  @@map("reviews")
}

// Homepage Hero Banners (carousel)
model Banner {
  id String @id @default(cuid())

  // Localized content
  titleEn      String
  titleAr      String
  subtitleEn   String?
  subtitleAr   String?
  buttonTextEn String?
  buttonTextAr String?

  // Image (full-width hero)
  imageUrl String // Cloudinary image URL
  publicId String // Cloudinary public ID for deletion

  // Link destination (collection slug, product slug, or external URL)
  linkUrl String?

  position Int     @default(0) // Display order in carousel
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position])
  @@index([isActive])
  @@map("banners")
}

// Instagram-style gallery posts (capella - FW25 Drops)
model InstagramPost {
  id String @id @default(cuid())

  imageUrl String // Cloudinary image URL
  publicId String // Cloudinary public ID for deletion

  // Optional link (can be external URL or internal product/collection)
  linkUrl String?
  altEn   String?
  altAr   String?

  position Int     @default(0) // Display order
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position])
  @@index([isActive])
  @@map("instagram_posts")
}
