enum FormType {
  CONTACT
  NEWSLETTER
  CUSTOM_ORDER
}

enum FormStatus {
  PENDING
  REVIEWED
  RESOLVED
  SPAM
}

model FormSubmission {
  id     String     @id @default(cuid())
  type   FormType   @default(CONTACT)
  status FormStatus @default(PENDING)

  // Use JSON to store various form payloads dynamically
  payload Json

  // Identification (if logged in)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId String?

  adminNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([userId])
  @@map("form_submissions")
}
