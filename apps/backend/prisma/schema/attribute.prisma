model Material {
  id       String @id @default(cuid())
  nameEn   String
  nameAr   String
  position Int    @default(0)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([nameEn])
  @@unique([nameAr])
  @@index([nameEn])
  @@index([position])
  @@map("materials")
}

